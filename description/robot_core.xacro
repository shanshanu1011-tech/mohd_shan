<?xml version="1.0"?>
<robot name="hai_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- BASE LINK -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <mass value="8.0"/>
      <inertia ixx="0.08" iyy="0.12" izz="0.18" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="package://mohd_shan/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0.075"/>
      <geometry>
        <box size="0.30 0.20 0.06"/>
      </geometry>
    </collision>
  </link>

  <!-- ========= WHEELS ========= -->

  <!-- FRONT RIGHT -->
  <link name="Link_FR">
    <inertial>
      <mass value="0.35"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
    </inertial>

    <visual>
      <origin xyz="-0.095294 0.124382 -0.009657"/>
      <geometry>
        <mesh filename="package://mohd_shan/meshes/wheel_FR_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <!-- FIXED: collision aligned -->
    <collision>
      <geometry>
        <cylinder radius="0.033" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_FR" type="continuous">
    <parent link="base_link"/>
    <child link="Link_FR"/>
    <origin xyz="0.095294 -0.124382 0.033"/>
    <axis xyz="0 -1 0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>


  <!-- FRONT LEFT -->
  <link name="Link_FL">
    <inertial>
      <mass value="0.35"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
    </inertial>

    <visual>
      <origin xyz="-0.095294 -0.090848 -0.009657"/>
      <geometry>
        <mesh filename="package://mohd_shan/meshes/wheel_FL_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.033" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_FL" type="continuous">
    <parent link="base_link"/>
    <child link="Link_FL"/>
    <origin xyz="0.095294 0.090848 0.033"/>
    <axis xyz="0 -1 0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>


  <!-- BACK LEFT -->
  <link name="Link_BL">
    <inertial>
      <mass value="0.35"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
    </inertial>

    <visual>
      <origin xyz="0.105062 -0.090848 -0.009657"/>
      <geometry>
        <mesh filename="package://mohd_shan/meshes/wheel_BL_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.033" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_BL" type="continuous">
    <parent link="base_link"/>
    <child link="Link_BL"/>
    <origin xyz="-0.105062 0.090848 0.033"/>
    <axis xyz="0 -1 0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>


  <!-- BACK RIGHT -->
  <link name="Link_BR">
    <inertial>
      <mass value="0.35"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
    </inertial>

    <visual>
      <origin xyz="0.105062 0.124382 -0.009657"/>
      <geometry>
        <mesh filename="package://mohd_shan/meshes/wheel_BR_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.033" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_BR" type="continuous">
    <parent link="base_link"/>
    <child link="Link_BR"/>
    <origin xyz="-0.105062 -0.124382 0.033"/>
    <axis xyz="0 -1 0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

</robot>
